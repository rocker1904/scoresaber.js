{
    "name": "scoresaber.js",
    "version": "1.0.0",
    "description": "Typed Node.js client for the ScoreSaber v2 API.",
    "keywords": [
        "scoresaber",
        "beat saber",
        "beatsaber",
        "api",
        "client",
        "rest",
        "typescript",
        "typed",
        "esm",
        "leaderboard"
    ],
    "type": "commonjs",
    "main": "./build/index.js",
    "module": "./build/index.mjs",
    "types": "./build/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./build/index.d.mts",
                "default": "./build/index.mjs"
            },
            "require": {
                "types": "./build/index.d.ts",
                "default": "./build/index.js"
            }
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "files": [
        "build"
    ],
    "engines": {
        "node": ">=20.3.0"
    },
    "scripts": {
        "gen:types": "openapi-typescript spec/openapi.json -o src/generated/openapi-types.ts",
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.test.json",
        "test": "tsx --test test/*.test.ts",
        "test:coverage": "c8 tsx --test test/*.test.ts",
        "smoke": "node scripts/smoke-exports.mjs",
        "docs": "typedoc",
        "fetch-spec": "node scripts/fetch-spec.mjs",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "api:update": "npm run build && api-extractor run --local",
        "api:check": "api-extractor run",
        "release": "npm run build && changeset publish",
        "prepack": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rocker1904/scoresaber.js.git"
    },
    "author": "Rocker1904",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/rocker1904/scoresaber.js/issues"
    },
    "homepage": "https://github.com/rocker1904/scoresaber.js#readme",
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@eslint/js": "^10.0.1",
        "@microsoft/api-extractor": "^7.58.7",
        "@types/node": "^24.13.1",
        "ajv": "^8.20.0",
        "c8": "^11.0.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "openapi-typescript": "^7.13.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsup": "^8.5.1",
        "tsx": "^4.22.4",
        "typedoc": "^0.28.19",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.60.1"
    }
}
