{
  "name": "scoresaber.js",
  "version": "1.0.0",
  "description": "Typed Node.js client for the ScoreSaber v2 API.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "./build"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen:types": "openapi-typescript spec/openapi.json -o src/generated/openapi-types.ts",
    "build": "rimraf ./build && tsc",
    "test": "tsx --test test/*.test.ts",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rocker1904/scoresaber.js.git"
  },
  "author": "Rocker1904",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rocker1904/scoresaber.js/issues"
  },
  "homepage": "https://github.com/rocker1904/scoresaber.js#readme",
  "devDependencies": {
    "@types/node": "^24.13.1",
    "openapi-typescript": "^7.13.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
